{
  "name": "@sidecodeapp/menubar",
  "version": "0.0.1",
  "private": true,
  "description": "macOS menu bar app for sidecode — Electron + React 19 + Tailwind",
  "author": "sidecode",
  "type": "module",
  "main": "dist-electron/main.js",
  "os": [
    "darwin"
  ],
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview",
    "package:mac": "pnpm --filter '@sidecodeapp/menubar...' run build && electron-builder --mac --arm64 --publish never",
    "package:mac:publish": "pnpm --filter '@sidecodeapp/menubar...' run build && set -a && { . ./.env.local 2>/dev/null || true; } && set +a && electron-builder --mac --arm64 --publish always"
  },
  "dependencies": {
    "@sidecodeapp/daemon": "workspace:*",
    "@tanstack/react-query": "^5.94.0",
    "electron-updater": "^6.8.9",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-qrcode-logo": "^4.1.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@types/react": "^19.2",
    "@types/react-dom": "^19.2",
    "@vitejs/plugin-react": "^6.0.2",
    "electron": "42.1.0",
    "tailwindcss": "^4.3.0",
    "vite": "^8.0.13",
    "vite-plugin-electron": "1.0.0-beta.10",
    "electron-builder": "^26.15.2"
  }
}
