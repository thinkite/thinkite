---
import "../styles/global.css";
import { site } from "../config";

interface Props {
  title?: string;
  description?: string;
  noindex?: boolean;
}

const {
  title = "sidecode — By your side. Run Claude Code from your phone.",
  description = "Run Claude Code from your phone: a macOS menu-bar daemon + iOS app to start, stream, and steer sessions on your Mac. Peer-to-peer, private, open source.",
  noindex = false,
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" sizes="any" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <meta name="generator" content={Astro.generator} />
    {noindex && <meta name="robots" content="noindex, follow" />}
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={site.url} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Geist:wght@400;500;600;700&family=Geist+Mono:wght@400;500&family=Instrument+Serif:ital@0;1&display=swap"
      rel="stylesheet"
    />

    {/* Inline UA detection — runs synchronously before paint to avoid FOUC */}
    <script is:inline>
      (function () {
        var ua = navigator.userAgent;
        var isIPadPro = /Macintosh/.test(ua) && "ontouchend" in document;
        var platform = "desktop";
        if (/iPhone|iPad|iPod/.test(ua) || isIPadPro) {
          platform = "ios";
        } else if (/Android/.test(ua)) {
          platform = "android";
        } else if (/Mobile|Phone|KAIOS|HarmonyOS|Tizen/i.test(ua)) {
          platform = "android";
        }
        document.documentElement.dataset.platform = platform;
      })();
    </script>
  </head>
  <body>
    <slot />
  </body>
</html>
