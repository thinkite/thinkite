---
const faqs = [
  {
    q: "What does it cost?",
    a: "Nothing. sidecode is free and open source under Apache 2.0 — no signup, no accounts. Usage bills against your existing Claude plan, exactly like running Claude Code yourself.",
  },
  {
    q: "How private is it, really?",
    a: "Your phone and Mac connect device-to-device over a DTLS-encrypted WebRTC DataChannel. A Cloudflare signaling server only brokers the initial handshake and never sees session content; when a direct link isn't possible, an encrypted TURN relay is the fallback.",
  },
  {
    q: "Do I need an account?",
    a: "No. sidecode uses your existing Claude login from the macOS keychain — your credentials never leave your Mac.",
  },
  {
    q: "Does it use my Claude Desktop sessions?",
    a: "No — sidecode owns its own sessions. You can opt in to <em>bridge</em> a session to <code>claude.ai</code> and Claude Desktop per session, but nothing is read from Desktop by default.",
  },
  {
    q: "Can I approve permission prompts from my phone?",
    a: "Not in this version. Sessions run with permissions bypassed, so there's no on-phone approval step yet.",
  },
  {
    q: "What do I need to run it?",
    a: "A Mac on Apple Silicon for the menu-bar app, and an iPhone for the iOS app — currently in TestFlight beta. Android isn't available yet.",
  },
];
---

<section class="section" id="faq">
  <div class="wrap-tx">
    <div class="section-head" style="grid-template-columns: 1fr;">
      <div>
        <h2>Questions, briefly.</h2>
      </div>
    </div>

    <dl class="faq-list">
      {
        faqs.map((faq) => (
          <div class="faq-item">
            <dt>{faq.q}</dt>
            <dd set:html={faq.a} />
          </div>
        ))
      }
    </dl>
  </div>
</section>
