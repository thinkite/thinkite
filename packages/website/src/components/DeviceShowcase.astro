---
import { Image } from "astro:assets";
import menubar from "../assets/menubar.png";
import iosSession from "../assets/ios-session.png";
---

<div class="wrap showcase-wrap">
  <div class="showcase">
    <div class="showcase-inner">
      {/* macOS menu bar */}
      <div class="showcase-cell">
        <span class="showcase-tag">01 · macOS menu bar</span>
        <div
          class="menu-shot"
          role="img"
          aria-label="sidecode macOS menu bar dropdown"
        >
          <Image
            src={menubar}
            alt="sidecode menu bar dropdown — Claude plan usage, Pair new device, and app controls"
          />
        </div>
      </div>

      {/* iOS app */}
      <div class="showcase-cell">
        <span class="showcase-tag">02 · iOS app</span>
        <div
          class="phone has-shot"
          role="img"
          aria-label="sidecode iOS session view"
        >
          <div class="phone-screen">
            <Image
              src={iosSession}
              alt="sidecode iOS app — a Claude Code session streaming markdown, a code snippet and a diff on iPhone"
            />
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
