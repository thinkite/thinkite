---
const features = [
  {
    ix: "01 · remote start",
    title: "Start a session from your phone.",
    body: "Pick any folder on your Mac and kick off a fresh Claude Code session remotely — not just resume one that's already running.",
  },
  {
    ix: "02 · private",
    title: "Peer-to-peer, private by default.",
    body: "Your phone talks straight to your Mac over a DTLS-encrypted WebRTC channel. The signaling server only brokers the connection — it never sees your session.",
  },
  {
    ix: "03 · real-time",
    title: "Real-time, resilient streaming.",
    body: "Responses stream token-by-token. Lose signal mid-response and sidecode reconnects, replaying only the events you missed.",
  },
  {
    ix: "04 · bridge",
    title: "Bridge on demand.",
    body: "Opt in per session to mirror it to <code>claude.ai</code> and Claude Desktop for cross-client control. Everything else stays private, P2P.",
  },
  {
    ix: "05 · native",
    title: "Mobile-native rendering.",
    body: "Streaming markdown that's selectable and syntax-highlighted, plus a fast diff viewer for every tool call.",
  },
  {
    ix: "06 · auth",
    title: "Local-first auth.",
    body: "Uses your existing Claude login from the keychain. Credentials never leave your Mac, and usage bills against your plan — just like running Claude Code yourself.",
  },
];
---

<section class="section" id="features">
  <div class="wrap">
    <div class="section-head is-stacked">
      <div class="eyebrow">/ what it does</div>
      <div>
        <h2>Claude Code, <span class="ital">from your pocket.</span></h2>
      </div>
    </div>

    <div class="features is-grid">
      {
        features.map((feature) => (
          <div class="feature">
            <div class="ix">{feature.ix}</div>
            <h3 set:html={feature.title} />
            <p set:html={feature.body} />
          </div>
        ))
      }
    </div>
  </div>
</section>
