---
import { links, site } from "../config";

interface Props {
  /** When true, renders only the bottom meta row (copyright + links).
      Use on content pages like /privacy that don't need the giant
      "sidecode." sign-off and download CTAs. */
  minimal?: boolean;
}

const { minimal = false } = Astro.props;
const currentYear = new Date().getFullYear();
---

<footer
  class={`foot ${minimal ? "is-minimal" : ""}`}
  id={minimal ? undefined : "download"}
>
  <div class="wrap">
    {
      !minimal && (
        <>
          <h2 class="foot-huge">
            sidecode<span class="ital">.</span>
          </h2>

          <div class="foot-actions">
            <a class="btn btn-accent" href={links.download}>
              Download for macOS
            </a>
            <a class="btn btn-ghost" href={links.appStore}>
              iOS · TestFlight <span class="arr">↗</span>
            </a>
            <a
              class="btn btn-ghost"
              href={links.github}
              target="_blank"
              rel="noopener"
            >
              View on GitHub <span class="arr">↗</span>
            </a>
          </div>

          <p class="foot-disclaimer">
            Not affiliated with, or endorsed by, Anthropic. “Claude” and “Claude
            Code” are trademarks of Anthropic, PBC. sidecode is early,
            open-source software — expect rough edges.
          </p>
        </>
      )
    }

    <div class="foot-grid">
      <div class="meta">
        © {currentYear} · {site.author} · {site.license} ·{" "}
        <b>macOS (Apple Silicon) + iOS</b>
      </div>
      <div class="links">
        <a href="/privacy">Privacy</a>
        <a href={`mailto:${links.contactEmail}`}>{links.contactEmail}</a>
      </div>
    </div>
  </div>
</footer>
