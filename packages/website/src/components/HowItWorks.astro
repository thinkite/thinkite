---
const steps = [
  {
    n: "01",
    title: "Install",
    body: "Download for macOS, drag sidecode into Applications, and it lives in your menu bar. No installer, no config, no terminal left running.",
  },
  {
    n: "02",
    title: "Pair",
    body: "Click <em style='font-style:normal'>Pair</em> and scan the QR with the iOS app from TestFlight. Your phone and Mac connect directly — peer-to-peer.",
  },
  {
    n: "03",
    title: "Start a session",
    body: "Pick any folder on your Mac and kick off a fresh Claude Code session — or jump into a running one. Responses stream back token-by-token, wherever you are.",
  },
];
---

<section class="section" id="how">
  <div class="wrap">
    <div class="section-head is-stacked">
      <div class="eyebrow">/ three steps</div>
      <div>
        <h2>Install. Pair. <span class="ital">Drive.</span></h2>
      </div>
    </div>

    <div class="steps">
      {
        steps.map((step) => (
          <div class="step">
            <div class="n">
              {step.n}
              <span class="slash">/</span>
            </div>
            <h3>{step.title}</h3>
            <p set:html={step.body} />
          </div>
        ))
      }
    </div>
  </div>
</section>
