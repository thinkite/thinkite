---
import BrandMark from "./BrandMark.astro";
import { links } from "../config";
---

<nav class="nav">
  <div class="wrap nav-inner">
    <a class="brand" href="/#top" aria-label="sidecode home">
      <span class="mark"><BrandMark /></span>
      sidecode
    </a>

    <div class="nav-cta">
      <div data-show-on="desktop">
        <a href={links.appStore}>iOS · TestFlight</a>
        <a href={links.github} target="_blank" rel="noopener">GitHub ↗</a>
        <a class="btn btn-primary" href={links.download}>
          Download <span class="arr">↓</span>
        </a>
      </div>

      <div data-show-on="ios">
        <a href={links.download}>macOS app</a>
        <a href={links.github} target="_blank" rel="noopener">GitHub ↗</a>
        <a class="btn btn-primary" href={links.appStore}>
          Get on TestFlight <span class="arr">↗</span>
        </a>
      </div>

      <div data-show-on="android">
        <a href={links.download}>macOS app</a>
        <a href="#faq">Why iOS first</a>
        <a class="btn btn-primary" href={links.github} target="_blank" rel="noopener">
          Star on GitHub <span class="arr">↗</span>
        </a>
      </div>
    </div>
  </div>
</nav>
