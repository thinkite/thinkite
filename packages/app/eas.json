{
  "cli": {
    "version": ">= 12.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development",
      "env": {
        "APP_VARIANT": "development",
        "SHARP_IGNORE_GLOBAL_LIBVIPS": "1"
      }
    },
    "preview": {
      "distribution": "internal",
      "channel": "preview",
      "autoIncrement": true,
      "env": {
        "APP_VARIANT": "preview",
        "SHARP_IGNORE_GLOBAL_LIBVIPS": "1"
      }
    },
    "production": {
      "distribution": "store",
      "channel": "production",
      "autoIncrement": true,
      "env": {
        "APP_VARIANT": "production",
        "SHARP_IGNORE_GLOBAL_LIBVIPS": "1"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleTeamId": "KX4PZHC9R3",
        "bundleIdentifier": "app.sidecode",
        "ascAppId": "6777824360"
      }
    }
  }
}
