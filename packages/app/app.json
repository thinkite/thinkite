{
  "expo": {
    "name": "Sidecode",
    "slug": "sidecode",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "sidecode",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/sidecode.icon",
      "bundleIdentifier": "app.sidecode",
      "associatedDomains": ["applinks:sidecode.app"],
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      },
      "bitcode": false
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "app.sidecode",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.INTERNET",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.SYSTEM_ALERT_WINDOW",
        "android.permission.WAKE_LOCK",
        "android.permission.BLUETOOTH"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#111110",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 128
        }
      ],
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow sidecode to scan pair QR codes from your Mac."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow sidecode to attach photos from your library to messages.",
          "cameraPermission": "Allow sidecode to take photos to attach to messages."
        }
      ],
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "26.0"
          }
        }
      ],
      "expo-image",
      "expo-web-browser",
      [
        "expo-font",
        {
          "fonts": [
            "../../node_modules/@expo-google-fonts/jetbrains-mono/400Regular/JetBrainsMono_400Regular.ttf",
            "../../node_modules/@expo-google-fonts/jetbrains-mono/700Bold/JetBrainsMono_700Bold.ttf"
          ]
        }
      ],
      "@config-plugins/react-native-webrtc",
      "expo-status-bar"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "0fe45941-a0e5-44f4-a681-65548d572da0"
      }
    },
    "runtimeVersion": {
      "policy": "fingerprint"
    },
    "updates": {
      "url": "https://u.expo.dev/0fe45941-a0e5-44f4-a681-65548d572da0"
    }
  }
}
