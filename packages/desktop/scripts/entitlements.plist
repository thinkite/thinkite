<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!-- The 5 entitlements deno's own CLI ships (cli/entitlements.plist):
       V8 needs JIT under Hardened Runtime, and our vendored pty FFI dylib
       needs library validation relaxed. `deno desktop` signs the webview
       host with EMPTY entitlements → silent launch crash under a real
       identity (sidecode#23); package.sh re-signs with these. -->
  <key>com.apple.security.cs.allow-jit</key>
  <true/>
  <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
  <true/>
  <key>com.apple.security.cs.disable-executable-page-protection</key>
  <true/>
  <key>com.apple.security.cs.allow-dyld-environment-variables</key>
  <true/>
  <key>com.apple.security.cs.disable-library-validation</key>
  <true/>
</dict>
</plist>
