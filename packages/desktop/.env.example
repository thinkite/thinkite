# Codesign + notarization credentials for `bun run package`.
# Copy to .env.local (gitignored) and fill in — the package script sources
# it before invoking the electrobun CLI. Values are personal/secret; never
# commit the real file.

# Signing identity — the Developer ID Application certificate's full name
# as shown in Keychain Access (Xcode > Settings > Accounts > Manage
# Certificates > + > "Developer ID Application" to create one).
ELECTROBUN_DEVELOPER_ID="Developer ID Application: <name> (KX4PZHC9R3)"
ELECTROBUN_TEAMID="KX4PZHC9R3"

# Notarization, option A: Apple ID + app-specific password
# (account.apple.com > App-Specific Passwords).
ELECTROBUN_APPLEID="you@example.com"
ELECTROBUN_APPLEIDPASS="xxxx-xxxx-xxxx-xxxx"

# Notarization, option B (CI-friendly, replaces option A): App Store
# Connect API key (Users and Access > Integrations). DEVELOPER_ID and
# TEAMID above are still required for the codesign step.
# ELECTROBUN_APPLEAPIKEYPATH="/path/to/AuthKey_XXXXXXXXXX.p8"
# ELECTROBUN_APPLEAPIKEY="XXXXXXXXXX"
# ELECTROBUN_APPLEAPIISSUER="xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
