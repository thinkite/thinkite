{
  "name": "@sidecodeapp/protocol",
  "version": "0.0.0",
  "private": true,
  "description": "Wire protocol shared between sidecode daemon and clients",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
