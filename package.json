{
  "name": "@sidecodeapp/sidecode",
  "version": "0.0.0",
  "private": true,
  "description": "",
  "packageManager": "bun@1.3.14",
  "workspaces": {
    "packages": [
      "packages/desktop",
      "packages/app",
      "packages/daemon",
      "packages/protocol",
      "packages/signaling",
      "packages/website"
    ],
    "catalog": {
      "react": "19.2.3",
      "react-dom": "19.2.3",
      "zod": "^4.4.3",
      "@types/node": "^24.12.2",
      "@tanstack/react-db": "^0.1.92",
      "@pierre/diffs": "^1.2.12",
      "tailwindcss": "^4.3.2"
    }
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "bun run --cwd packages/protocol typecheck && bun run --cwd packages/daemon typecheck && bun run --cwd packages/desktop typecheck && bun run --cwd packages/app typecheck",
    "build": "bun run --cwd packages/protocol build && bun run --cwd packages/daemon build",
    "lint": "biome check .",
    "format": "biome check --write ."
  },
  "keywords": [],
  "author": "",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=24"
  },
  "overrides": {
    "react": "19.2.3",
    "react-dom": "19.2.3"
  },
  "trustedDependencies": [
    "node-datachannel"
  ],
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "typescript": "~6.0.3",
    "vitest": "^4.1.5"
  }
}
